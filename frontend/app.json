{
  "expo": {
    "name": "PesoPilot",
    "slug": "pesopilot",
    "scheme": "pesopilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "plugins": ["expo-router", "expo-secure-store"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B5D4B"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiUrl": "http://192.168.1.15:4000/api"
    }
  }
}
