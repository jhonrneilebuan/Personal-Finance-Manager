{
  "name": "pesopilot",
  "version": "1.0.0",
  "private": true,
  "description": "PesoPilot AI-ready personal finance manager monorepo",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run start --workspace frontend",
    "build": "npm run build --workspace backend && npm run typecheck --workspace frontend",
    "lint": "npm run lint --workspaces"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-gesture-handler": "2.31.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-gesture-handler": "2.31.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-worklets": "0.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
